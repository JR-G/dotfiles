{
  "workbench.colorTheme": "Rosé Pine Moon (no italics)",
  "editor.minimap.enabled": false,
  "workbench.iconTheme": "material-icon-theme",
  "editor.lineNumbers": "relative",
  "workbench.activityBar.location": "hidden",
  "window.commandCenter": false,
  "workbench.layoutControl.enabled": false,
  "window.title": "${rootName}",
  "workbench.editor.showIcons": false,
  "explorer.compactFolders": false,
  "workbench.statusBar.visible": false,
  "breadcrumbs.icons": false,
  "vim.useSystemClipboard": true,
  "workbench.panel.defaultLocation": "right",
  "editor.formatOnSave": true,
  "terminal.integrated.cursorStyle": "block",
  "[yaml]": {
    "editor.formatOnSave": false
  },
  "[markdown]": {
      "editor.formatOnSave": false,
      "editor.defaultFormatter": null
    },
    "custom-ui-style.electron": {
      "frame": true,
      "tranparent": true,
      "opacity": 0.95
    },

  "workbench.colorCustomizations": {
    "[Rosé Pine Moon (no italics)]": {
      "editor.background": "#232136",
      "editor.foreground": "#e0def4",
      "editorLineNumber.foreground": "#6e6a86",
      "editorLineNumber.activeForeground": "#908caa",
      "editorCursor.foreground": "#e0def4",
      "editor.selectionBackground": "#44415a",
      "editor.inactiveSelectionBackground": "#2a283e",
      "editor.lineHighlightBackground": "#2a283e",
      "editorBracketMatch.border": "#56526e",
      "editorBracketMatch.background": "#2a283e",
      "editorIndentGuide.background1": "#393552",
      "editorIndentGuide.activeBackground1": "#44415a",

      "sideBar.background": "#2a273f",
      "sideBar.foreground": "#e0def4",
      "sideBar.border": "#393552",
      "activityBar.background": "#2a273f",
      "activityBar.foreground": "#e0def4",
      "activityBarBadge.background": "#3e8fb0",
      "activityBarBadge.foreground": "#232136",

      "tab.activeBackground": "#232136",
      "tab.activeForeground": "#e0def4",
      "tab.inactiveBackground": "#2a273f",
      "tab.inactiveForeground": "#908caa",
      "tab.border": "#393552",
      "editorGroupHeader.tabsBackground": "#2a273f",
      "editorGroup.border": "#393552",

      "panel.background": "#2a273f",
      "panel.border": "#393552",
      "statusBar.background": "#2a273f",
      "statusBar.foreground": "#e0def4",
      "titleBar.activeBackground": "#2a273f",
      "titleBar.activeForeground": "#e0def4",

      "terminal.background": "#232136",
      "terminal.foreground": "#e0def4",
      "terminalCursor.foreground": "#e0def4",

      "terminal.ansiBlack": "#393552",
      "terminal.ansiRed": "#eb6f92",
      "terminal.ansiGreen": "#95b1ac",
      "terminal.ansiYellow": "#f6c177",
      "terminal.ansiBlue": "#3e8fb0",
      "terminal.ansiMagenta": "#c4a7e7",
      "terminal.ansiCyan": "#9ccfd8",
      "terminal.ansiWhite": "#e0def4",
      "terminal.ansiBrightBlack": "#6e6a86",
      "terminal.ansiBrightRed": "#eb6f92",
      "terminal.ansiBrightGreen": "#95b1ac",
      "terminal.ansiBrightYellow": "#f6c177",
      "terminal.ansiBrightBlue": "#3e8fb0",
      "terminal.ansiBrightMagenta": "#c4a7e7",
      "terminal.ansiBrightCyan": "#9ccfd8",
      "terminal.ansiBrightWhite": "#ffffff0f"
    }
  },

  "editor.semanticHighlighting.enabled": "configuredByTheme",

  "editor.semanticTokenColorCustomizations": {
    "[Rosé Pine Moon (no italics)]": {
      "rules": {
        "parameter": "#c4a7e7",

        "variable": "#e0def4",
        "variable.local": "#c4a7e7",

        "property": "#9ccfd8",
        "property.readonly": "#9ccfd8",
        "member": "#9ccfd8",

        "function": "#ea9a97",
        "method": "#ea9a97",

        "operator": "#6e6a86",
        "keyword": "#3e8fb0",

        "string": "#f6c177",
        "number": "#f6c177",
        "boolean": "#ea9a97",

        "class": "#9ccfd8",
        "interface": "#9ccfd8",
        "type": "#9ccfd8",
        "typeParameter": "#9ccfd8",
        "namespace": "#9ccfd8",
        "enum": "#f6c177",
        "enumMember": "#f6c177",
        "label": "#908caa"
      }
    }
  },

  "editor.tokenColorCustomizations": {
    "[Rosé Pine Moon (no italics)]": {
      "comments": "#6e6a86",
      "keywords": "#3e8fb0",
      "strings": "#f6c177",
      "numbers": "#f6c177",
      "functions": "#ea9a97",
      "types": "#9ccfd8",
      "variables": "#e0def4",
      "textMateRules": [
        {
          "name": "Parameters (fallback if semantic off)",
          "scope": ["variable.parameter", "meta.parameter"],
          "settings": { "foreground": "#c4a7e7" }
        },
        {
          "name": "Object literal keys & properties",
          "scope": [
            "meta.object-literal.key",
            "support.type.property-name",
            "meta.property.object",
            "variable.other.property",
            "variable.other.object.property"
          ],
          "settings": { "foreground": "#9ccfd8" }
        },
        {
          "name": "Members in member expressions",
          "scope": ["variable.other.member", "meta.property.member"],
          "settings": { "foreground": "#9ccfd8" }
        },
        {
          "name": "Function names and calls (fallback)",
          "scope": [
            "entity.name.function",
            "support.function",
            "meta.function-call",
            "meta.method-call"
          ],
          "settings": { "foreground": "#ea9a97" }
        },
        {
          "name": "Variables (fallback)",
          "scope": ["variable", "variable.other.readwrite"],
          "settings": { "foreground": "#e0def4" }
        },
        {
          "name": "Operators & punctuation (fallback)",
          "scope": ["keyword.operator", "punctuation", "meta.brace", "meta.delimiter"],
          "settings": { "foreground": "#6e6a86" }
        }
      ]
    }
  },

  "editor.bracketPairColorization.enabled": true,
  "editor.cursorStyle": "line"
}
